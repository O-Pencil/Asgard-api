# Database URL
# For InsForge/cloud Postgres, paste the provider connection string here.
# Both postgresql:// and postgres:// are accepted and normalized to asyncpg.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/asgard
DB_TABLE_PREFIX=asgard_

# JWT Secret Key (change in production)
JWT_SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
# Allowed hosts for CORS (comma-separated, for production use)
# ALLOWED_HOSTS=https://admin.example.com,https://app.example.com

# OpenAI Compatibility
OPENAI_API_BASE=http://localhost:8000/v1

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO

# Pencil Agent Gateway
PENCIL_GATEWAY_URL=http://pencil-gateway:8080
PENCIL_GATEWAY_INTERNAL_KEY=pk_internal_asgard
# PENCIL_GATEWAY_CONNECT_TIMEOUT_S=5
# PENCIL_GATEWAY_READ_TIMEOUT_S=

# Hosted preview defaults. Provider credentials are configured on Gateway,
# not stored in Asgard DB records.
SINGLE_USER_MODE=true
ADMIN_EMAIL=admin@asgard.dev
ADMIN_PASSWORD=change-me
PENCIL_DEFAULT_PROVIDER=openai
PENCIL_DEFAULT_MODEL=gpt-4.1-mini
